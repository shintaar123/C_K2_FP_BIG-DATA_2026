# Salin file ini jadi .env lalu isi nilainya
# cp .env.example .env   (Linux/Mac)
# copy .env.example .env  (Windows)

# MinIO credentials
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# Hive Metastore database
HIVE_PG_USER=hive
HIVE_PG_PASSWORD=hivepassword
HIVE_PG_DB=metastore

# Superset
SUPERSET_SECRET_KEY=ganti_dengan_string_acak_panjang_minimal_32_karakter

# ─── LLM Provider (Pipeline + LLM) — semua GRATIS, isi minimal salah satu ───
# Fallback chain: Gemini -> NVIDIA -> Groq -> Cerebras -> rule-based (tanpa key tetap jalan)
# Gemini  : https://aistudio.google.com/apikey  (1.500 req/hari gratis)
GEMINI_API_KEY=
# NVIDIA NIM: https://build.nvidia.com  (key diawali "nvapi-", perlu verifikasi OTP HP)
NVIDIA_API_KEY=
# Groq    : https://console.groq.com/keys
GROQ_API_KEY=
# Cerebras: https://cloud.cerebras.ai
CEREBRAS_API_KEY=
# (opsional) override nama model
# GEMINI_MODEL=gemini-2.5-flash
# NVIDIA_MODEL=z-ai/glm-5.1
# GROQ_MODEL=llama-3.3-70b-versatile
# CEREBRAS_MODEL=llama-3.3-70b